# RPC (offentlig fungerer, brug Alchemy i produktion)
NEXT_PUBLIC_RPC_URL=https://rpc.mainnet.chain.robinhood.com

# StockDrops-kontraktens adresse efter deploy
NEXT_PUBLIC_CONTRACT_ADDRESS=

# Givest token (holder fee discounts). Leave empty until token is live.
NEXT_PUBLIC_GIVEST_TOKEN=

# Wallet der betaler gas for claims. Skal have lidt ETH på Robinhood Chain.
# Brug en dedikeret nøgle, IKKE din primære wallet.
# Protocol fees also land on feeRecipient (set at deploy — usually this wallet).
RELAYER_PRIVATE_KEY=

# X (Twitter) OAuth til "connect X" på send-siden.
# Opret app på https://developer.x.com → OAuth 2.0, type: Web App.
# Callback URL: https://usegivest.app/api/auth/x/callback
X_CLIENT_ID=
X_CLIENT_SECRET=

# Secret til session-cookies og sender-attestation.
# Valgfri — falder tilbage til RELAYER_PRIVATE_KEY hvis den ikke er sat.
SESSION_SECRET=

# MoonPay fiat onramp (kort / Apple Pay / Google Pay -> ETH pa Robinhood Chain).
# Opret partner-konto pa https://dashboard.moonpay.com og enable eth_robinhood.
# Valgfri - "Buy with card"-knappen vises kun nar publishable key er sat.
MOONPAY_PUBLISHABLE_KEY=
MOONPAY_SECRET_KEY=
