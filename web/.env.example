# RPC (the public endpoint works; use a dedicated provider in production)
NEXT_PUBLIC_RPC_URL=https://rpc.mainnet.chain.robinhood.com

# StockDrops escrow contract address (after deploy)
NEXT_PUBLIC_CONTRACT_ADDRESS=

# Givest token (holder fee discounts). Leave empty until the token is live.
NEXT_PUBLIC_GIVEST_TOKEN=

# Wallet that pays gas for claims. Needs a little ETH on Robinhood Chain.
# Use a dedicated key, NOT your main wallet.
# Protocol fees also land on feeRecipient (set at deploy - usually this wallet).
RELAYER_PRIVATE_KEY=

# X (Twitter) OAuth for "connect X" on the send page.
# Create an app at https://developer.x.com -> OAuth 2.0, type: Web App.
# Callback URL: https://<your-domain>/api/auth/x/callback
X_CLIENT_ID=
X_CLIENT_SECRET=

# Secret for session cookies and sender attestation.
# Optional - falls back to RELAYER_PRIVATE_KEY if unset.
SESSION_SECRET=
